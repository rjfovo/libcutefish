#!/usr/bin/make -f

%:
	dh $@ --parallel

override_dh_auto_configure:
	dh_auto_configure -- -DEMBED_TRANSLATIONS=ON -DBUILD_TESTING=ON \
		-DCMAKE_INSTALL_FULL_LIBDIR=/usr/lib/x86_64-linux-gnu \
		-DINSTALL_QMLDIR=/usr/lib/x86_64-linux-gnu/qt6/qml

override_dh_auto_install:
	dh_auto_install --destdir=debian/libcutefish/

override_dh_install:
	dh_install
	# 修复qrc文件中的绝对路径问题
	if [ -d debian/libcutefish ]; then \
		find debian/libcutefish -name "*.qrc" -type f | while read qrc_file; do \
			echo "Fixing qrc file: $$qrc_file"; \
			sed -i 's|/workspace/cutefish_project/cutefish/code/libcutefish/obj-x86_64-linux-gnu/||g' "$$qrc_file"; \
		done; \
	fi
